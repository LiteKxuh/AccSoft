{
  "name": "hotelops",
  "private": false,
  "version": "1.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "HotelOps — premium hotel accounting, daily flash, payroll, scheduling, and night-audit ingestion suite.",
  "author": {
    "name": "LiteKxuh",
    "email": "noreply@hotelops.app"
  },
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder",
    "publish": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.hotelops.app",
    "productName": "HotelOps",
    "copyright": "Copyright © 2026 HotelOps",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.cache",
      "!**/{.eslintrc,.prettierrc,tsconfig.json}"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "artifactName": "HotelOps-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build-resources/icon-1024.png",
      "category": "public.app-category.business",
      "artifactName": "HotelOps-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build-resources/icon.png",
      "artifactName": "HotelOps-${version}.${ext}",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HotelOps",
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "include": null
    },
    "extraResources": [
      {
        "from": "build-resources/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build-resources/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "LiteKxuh",
        "repo": "AccSoft",
        "releaseType": "release"
      }
    ]
  }
}
